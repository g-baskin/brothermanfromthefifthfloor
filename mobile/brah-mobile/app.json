{
  "expo": {
    "name": "Brah Mobile",
    "slug": "brah-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "brahmobile",
    "android": {
      "package": "com.unstablemind.brahmobile",
      "permissions": ["INTERNET", "CAMERA", "RECORD_AUDIO"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Brah Mobile to scan the desktop pairing QR code."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Brah Mobile to record push-to-talk voice for desktop Brah.",
          "recordAudioAndroid": true,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-asset",
      "expo-secure-store"
    ],
    "extra": {
      "bridgeDefaultPort": 19455,
      "eas": {
        "projectId": "875cf078-e033-4e80-a91c-6c2659195245"
      }
    },
    "owner": "automationgod"
  }
}
